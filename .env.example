# --- Bot Configuration ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
CHANNEL_ID=-123456789
ADMIN_ID=123456789
BOT_MODE=polling  # options: polling, webhook
WEBHOOK_URL=https://your-app.vercel.app/webhook
PORT=3000

# --- GitHub Integration ---
GITHUB_TOKEN=your_github_pat

# --- AI Intelligence (OpenAI-compatible: Grok / DeepSeek) ---
AI_API_KEY=your_api_key
AI_MODEL=deepseek-chat   # Grok (X.ai): 'grok-beta', DeepSeek: 'deepseek-chat'
AI_BASE_URL=https://api.deepseek.com  # Grok (X.ai): 'https://api.x.ai/v1', DeepSeek: 'https://api.deepseek.com'

# --- Database (Supabase Ready) ---
# Currently the bot uses knowledge_base.json
# Uncomment and fill these to switch to Supabase later
# SUPABASE_URL=your_supabase_url
# SUPABASE_KEY=your_supabase_anon_key
# DB_MODE=json  # options: json, supabase
